generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  country   String?
  phone     String?
  role      Role     @default(USER)
  // Timestamped consent to store/process medical documents (PHI). Captured in
  // the chat flow before the first report upload; kept for compliance.
  medicalConsentAt DateTime?
  // Email verification: signup sends a tokenised link; login requires a
  // verified email before the first password login.
  emailVerifiedAt DateTime?
  verifyToken     String?   @unique
  verifyTokenExp  DateTime?
  // OTP email verification (6-digit code typed in-chat / on the verify screen).
  verifyOtp       String?
  verifyOtpExp    DateTime?
  verifyOtpTries  Int       @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports          Report[]
  bookings         Booking[]
  payments         Payment[]
  recoveryPlans    RecoveryPlan[]
  journeys         Journey[]
  tripServiceSteps TripServiceStep[]
  teleconsults     Teleconsult[]  @relation("PatientTeleconsults")
  familyLinks      FamilyLink[]   @relation("PatientFamily")
  familyOf         FamilyLink[]   @relation("FamilyMember")
  // The published hospital this account owns (role = HOSPITAL), created at go-live.
  hospital         Hospital?            @relation("HospitalOwner")
  // The onboarding application this account was provisioned from.
  hospitalApplication HospitalApplication? @relation("ApplicationOwner")

  @@map("users")
}

// One medical journey — a patient can run several (knee now, dental later).
// Groups the chat answers, AI outputs and step progress so the dashboard can
// resume any journey exactly where it stopped.
model Journey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  status      String   @default("ACTIVE") // ACTIVE | COMPLETED | ARCHIVED
  // Chat wizard answers
  treatment   String?
  city        String?
  urgency     String?
  homeCountry String?
  description String?
  travelDate  DateTime? // expected travel date (chat step; picker/chip/AI-parsed free text)
  urgent      Boolean   @default(false) // derived: travelDate < 30 days away → staff-prioritize
  // Step progress + AI output snapshots (shape mirrors the AI service JSON)
  step        String   @default("intake") // intake | analysis | recommendation | hospital | plan | travel | recovery | done
  reportId    String?
  analysis    Json?
  stayOrGo    Json?
  hospitalId  String?
  tripPlan    Json?
  // Live chat with the selected hospital (patient ↔ Curify staff on the hospital's
  // behalf): { messages: [{ id, sender, kind, body, reportId?, amountUsd?, at }] }.
  hospitalChat Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teleconsults Teleconsult[]

  @@index([userId, updatedAt])
  @@map("journeys")
}

enum Role {
  ADMIN
  USER
  AGENT
  HOSPITAL
}

// Onboarding lifecycle for a hospital-authored profile. `null` on a Hospital row
// means it came from the scraping/enrichment pipeline (always public); a set
// value means it was self-onboarded and is only visible once APPROVED.
enum ApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// Admin verdict on a single uploaded verification document.
enum DocStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ─── Hospital onboarding (BRD: public self-serve application → go-live) ───────

// Lifecycle of a self-serve hospital application (BRD flow Section 1).
enum OnboardingStatus {
  DRAFT              // application started
  CONTACT_VERIFYING  // authorised contact captured, OTPs pending
  ACCREDITATION      // choosing/verifying NABH/JCI
  VALIDATING         // non-accredited doc check in progress
  AGREEMENT          // ready to e-sign the commission agreement
  PROVISIONED        // credentials issued; awaiting first sign-in + setup
  SETUP              // dashboard setup (doctors, pricing, availability)
  LIVE               // published into patient matching
  REJECTED
}

enum AccreditationBody {
  NABH
  JCI
}

// How an accreditation was confirmed (BRD Appendix A: no live API).
enum AccreditationSource {
  REGISTRY
  CERT_UPLOAD
}

// Required documents for non-accredited hospitals (FR-11).
enum OnboardingDocType {
  REGISTRATION           // hospital/clinical-establishment registration
  COUNCIL_REGISTRATION   // practitioner council registrations
  FIRE_BUILDING_SAFETY
  BIOMEDICAL_WASTE       // biomedical-waste authorisation
  INDEMNITY_INSURANCE
  SIGNATORY_ID           // authorised-signatory ID
  // Doctor-level
  DOCTOR_PHOTO
  DOCTOR_DEGREE
  OTHER
}

// Who set an availability window (FR-27/28).
enum AvailabilitySource {
  SELF
  COORDINATOR
  CALENDAR
}

// Onboarding doctor review state (FR-22/23).
enum OnboardingDoctorStatus {
  APPROVED
  IN_REVIEW
  ON_LEAVE
}

model Report {
  id               String   @id @default(cuid())
  userId           String?
  reportRef        String   @unique
  filename         String?
  fileType         String?
  language         String?
  confidence       Int?
  conditionName    String?
  conditionMedical String?
  conditionPlain   String?
  severity         String?
  patientAge       Int?
  patientName      String?
  scanType         String?
  scanDate         String?
  referringDoctor  String?
  flags            Json?
  rawAnalysis      Json?
  treatment        String?
  country          String?
  urgency          String?
  createdAt        DateTime @default(now())

  // Cascade: deleting a user removes their reports (right-to-erasure).
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking?

  @@map("reports")
}

model Hospital {
  id                   String  @id
  name                 String
  city                 String
  country              String
  flag                 String?
  imageUrl             String?
  jciAccredited        Boolean @default(false)
  fairnessScore        Int?
  overallRating        Float?
  quotedPriceUsd       Int?
  localPriceUsd        Int?
  localBenchmarkUsd    Int?
  included             Json?
  notIncluded          Json?
  pros                 Json?
  cons                 Json?
  mysteryShopperScore  Int?
  patientsPerYear      Int?
  internationalPercent String?
  surgeonId            String?
  // Dynamic data fields
  specialty            String?
  procedures           Json?
  intlOfficePhone      String?
  intlOfficeEmail      String?
  website              String?
  // Location (Google Places)
  address              String?
  latitude             Float?
  longitude            Float?
  googleMapsUri        String?

  // ─── Published onboarded hospital (created at go-live) ──────────────────────
  // ownerUserId is set only for onboarded rows; scraped rows leave it null.
  // approvalStatus null = scraped/legacy (always public); APPROVED = published &
  // visible in matching (see the visibility gate in hospitals.service).
  ownerUserId          String?         @unique
  approvalStatus       ApprovalStatus?
  nabhAccredited       Boolean         @default(false)
  priority             Boolean         @default(false) // fast-track (accredited) ranking

  createdAt            DateTime @default(now())

  owner     User?                @relation("HospitalOwner", fields: [ownerUserId], references: [id])
  surgeon   Surgeon?             @relation("PrimarySurgeon", fields: [surgeonId], references: [id])
  doctors   Surgeon[]            @relation("HospitalDoctors")
  published HospitalApplication? @relation("PublishedHospital")
  reviews   Review[]
  bookings  Booking[]

  @@map("hospitals")
}

model Surgeon {
  id              String   @id
  name            String
  title           String?
  hospital        String?
  country         String?
  flag            String?
  photoUrl        String?
  specialization  String?
  yearsExperience Int?
  totalProcedures Int?
  aclSpecific     Int?
  successRate     Float?
  complications   Float?
  education       Json?
  publications    Int?
  languages       Json?
  awards          Json?
  patientRating   Float?
  avgSurgeryTime  String?
  nextAvailable   String?
  // ─── Published onboarded doctor (created at go-live from OnboardingDoctor) ──
  // hospitalId links a published doctor to its published hospital (many per
  // hospital). Scraped/legacy surgeons leave it null.
  hospitalId        String?
  email             String?
  medicalCouncilReg String?
  degrees           Json?
  createdAt       DateTime @default(now())

  // Hospitals for which THIS surgeon is the single primary/featured surgeon.
  primaryOf   Hospital[]         @relation("PrimarySurgeon")
  // The published hospital that owns this doctor.
  onboardingHospital Hospital?    @relation("HospitalDoctors", fields: [hospitalId], references: [id])

  @@map("surgeons")
}

// ─── Hospital onboarding entities (BRD §11) ───────────────────────────────────
// The self-serve application. Lives pre-login; mapped into Hospital/Surgeon only
// at go-live. ownerUserId is set at provisioning; publishedHospitalId at go-live.
model HospitalApplication {
  id                  String   @id @default(cuid())
  // Profile (FR-2 / FR-3)
  legalName           String
  city                String
  address             String?
  registrationNo      String?
  ownership           String?
  website             String?
  totalBeds           Int?
  icuBeds             Int?
  airportDistanceKm   Int?
  specialties         String[]
  insurers            String[]
  languages           String[]
  intlFacilities      String[]
  // Pricing & capacity (FR-21) — applied to the published Hospital at go-live.
  quotedPriceUsd      Int?
  patientsPerYear     Int?
  imageUrl            String?
  procedures          String[]
  // Package narrative (shown on the patient comparison card) — the panel edits
  // these; AI seeds pros/cons/included when the hospital asks. Published to Hospital.
  localBenchmarkUsd   Int?
  included            String[]
  notIncluded         String[]
  pros                Json?
  cons                Json?
  // Lifecycle
  status              OnboardingStatus @default(DRAFT)
  priority            Boolean          @default(false) // fast-track (verified accreditation)
  notAccredited       Boolean          @default(false)
  // Secret handle returned at apply; authorises the pre-login flow steps (NFR-1).
  sessionToken        String?          @unique
  ownerUserId         String?          @unique // set at provisioning
  publishedHospitalId String?          @unique // set at go-live
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  contact        AuthorisedContact?
  accreditations AccreditationRecord[]
  documents      OnboardingDocument[]
  agreement      CommissionAgreement?
  doctors        OnboardingDoctor[]
  owner          User?     @relation("ApplicationOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  published      Hospital? @relation("PublishedHospital", fields: [publishedHospitalId], references: [id], onDelete: SetNull)

  @@map("hospital_applications")
}

// Authorised contact + dual-channel OTP verification (FR-5 / FR-7).
model AuthorisedContact {
  id                 String   @id @default(cuid())
  applicationId      String   @unique
  name               String
  designation        String?
  workEmail          String
  whatsapp           String
  emailVerifiedAt    DateTime?
  whatsappVerifiedAt DateTime?
  emailOtp           String?
  emailOtpExp        DateTime?
  emailOtpTries      Int       @default(0)
  waOtp              String?
  waOtpExp           DateTime?
  waOtpTries         Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  application HospitalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  @@map("authorised_contacts")
}

// Accreditation record — registry-verified or certificate-upload (FR-9/10/13, BR-1/2/8).
model AccreditationRecord {
  id            String              @id @default(cuid())
  applicationId String
  body          AccreditationBody
  identifier    String?
  verifiedAt    DateTime?
  validUntil    DateTime?
  source        AccreditationSource @default(CERT_UPLOAD)
  status        DocStatus           @default(PENDING)
  createdAt     DateTime            @default(now())

  application HospitalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  @@index([applicationId])
  @@map("accreditation_records")
}

// Verification documents for non-accredited hospitals (FR-11). Disk-stored,
// streamed via an auth-guarded route. doctorId set for doctor-level docs.
model OnboardingDocument {
  id                 String            @id @default(cuid())
  applicationId      String
  doctorId           String?
  type               OnboardingDocType
  autoClassifiedType OnboardingDocType?
  fileUrl            String            // filename on disk (uploads/hospital-docs/…)
  originalName       String?
  status             DocStatus         @default(PENDING)
  note               String?
  reviewedBy         String?
  reviewedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  application HospitalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  doctor      OnboardingDoctor?   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  @@index([applicationId])
  @@map("onboarding_documents")
}

// Fixed-commission agreement, typed-name e-signature (FR-14/15/16, BR-3).
model CommissionAgreement {
  id            String   @id @default(cuid())
  applicationId String   @unique
  version       String
  percentage    Float
  payoutRail    String?
  signatoryName String
  ip            String?
  terms         Json?
  signedAt      DateTime @default(now())

  application HospitalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  @@map("commission_agreements")
}

// Doctor captured during onboarding (FR-21). Mapped → Surgeon at go-live via
// publishedSurgeonId. availabilityToken backs the private (WhatsApp) link.
model OnboardingDoctor {
  id                  String                 @id @default(cuid())
  applicationId       String
  photoUrl            String?
  name                String
  qualifications      String?
  specialty           String?
  subspecialty        String?
  yearsExperience     Int?
  registrationNo      String?
  languages           String[]
  bio                 String?
  proceduresPerformed Int?
  email               String?
  teleconsultEnabled  Boolean                @default(false)
  status              OnboardingDoctorStatus @default(IN_REVIEW)
  timezone            String                 @default("Asia/Kolkata") // IANA (FR-42)
  availabilityToken   String?                @unique
  publishedSurgeonId  String?                @unique // set at go-live
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  application HospitalApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  windows     AvailabilityWindow[]
  documents   OnboardingDocument[]
  teleconsults Teleconsult[]
  @@index([applicationId])
  @@map("onboarding_doctors")
}

enum TeleconsultStatus {
  SCHEDULED
  IN_PROGRESS // doctor has joined the room — "connected / live now"
  COMPLETED
  CANCELLED
}

// Who shared a document during a teleconsult (used by the monitoring view).
enum TeleconsultDocSender {
  DOCTOR
  PATIENT
}

// A booked patient↔doctor video consultation. Links a patient (User) to the
// onboarding doctor they'll meet (doctor joins via their availabilityToken, no
// login). roomName is the unguessable video room — only ever handed out through
// the two ownership-checked token endpoints.
model Teleconsult {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String            // OnboardingDoctor
  // The journey this consult belongs to — a journey may have only ONE active
  // consult at a time (enforced in TeleconsultService.book). Nullable so legacy /
  // dashboard-initiated consults without a journey still work.
  journeyId   String?
  scheduledAt DateTime
  roomName    String            @unique @default(cuid())
  status      TeleconsultStatus @default(SCHEDULED)
  // Lifecycle timestamps for monitoring: startedAt = doctor first joined
  // (connected), endedAt = marked complete. Duration = endedAt − startedAt.
  startedAt   DateTime?
  endedAt     DateTime?
  // Price quotation the doctor gives the patient after/around the consult.
  quoteAmount   Int?
  quoteCurrency String   @default("USD")
  quoteNote     String?
  quotedAt      DateTime?
  // When the patient accepted the quote — the go-signal that unlocks trip planning
  // (the accepted amount becomes the plan's treatment cost). Null = not yet accepted.
  quoteAcceptedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient   User                  @relation("PatientTeleconsults", fields: [patientId], references: [id], onDelete: Cascade)
  doctor    OnboardingDoctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  journey   Journey?              @relation(fields: [journeyId], references: [id], onDelete: SetNull)
  documents TeleconsultDocument[]

  @@index([patientId])
  @@index([doctorId, scheduledAt])
  @@index([journeyId])
  @@map("teleconsults")
}

// A file shared during a teleconsult (prescription, lab report, scan, quotation…).
// Stored on disk like verification docs; streamed via ownership-checked routes.
model TeleconsultDocument {
  id            String              @id @default(cuid())
  teleconsultId String
  sender        TeleconsultDocSender
  kind          String?             // e.g. "Prescription", "Lab report", "Scan"
  fileUrl       String              // filename on disk (HOSPITAL_DOCS_DIR)
  originalName  String?
  createdAt     DateTime            @default(now())

  teleconsult Teleconsult @relation(fields: [teleconsultId], references: [id], onDelete: Cascade)

  @@index([teleconsultId])
  @@map("teleconsult_documents")
}

// Recurring weekly availability window set by the doctor via the link (FR-27).
model AvailabilityWindow {
  id        String             @id @default(cuid())
  doctorId  String
  weekday   Int                // 0 = Sunday … 6 = Saturday
  start     String             // "HH:mm"
  end       String             // "HH:mm"
  recurring Boolean            @default(true)
  source    AvailabilitySource @default(SELF)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  doctor OnboardingDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  @@index([doctorId, weekday])
  @@map("availability_windows")
}

// ─── Reference master data (dropdown options for doctor profiles) ─────────────
// Editable lookup tables so the doctor form's dropdowns are DB-driven, not
// hardcoded. Seeded for production (scripts/seed_masters.ts).
model Specialty {
  id        String  @id @default(cuid())
  name      String  @unique
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  @@map("master_specialties")
}

model Qualification {
  id        String  @id @default(cuid())
  name      String  @unique
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  @@map("master_qualifications")
}

model Language {
  id        String  @id @default(cuid())
  name      String  @unique
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  @@map("master_languages")
}

model Timezone {
  id        String  @id @default(cuid())
  name      String  @unique // IANA, e.g. Asia/Kolkata
  label     String?         // e.g. "India (IST)"
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  @@map("master_timezones")
}

model Review {
  id           String   @id @default(cuid())
  hospitalId   String
  surgeonId    String?
  reviewerName String
  nationality  String?
  age          Int?
  procedure    String?
  rating       Int
  reviewDate   DateTime?
  text         String
  textEn       String?  // English translation (set only when lang != en); powers the review language toggle
  region       String?  // derived from nationality via the canonical region map (persisted for queries)
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  // Dynamic data fields
  lang         String?
  totalReviews Int?
  link         String?
  tokens       Json?
  flags        Json?
  contentHash  String?

  hospital Hospital @relation(fields: [hospitalId], references: [id])

  @@map("reviews")
}

model Booking {
  id           String        @id @default(cuid())
  userId       String
  reportId     String?       @unique
  hospitalId   String
  plan         Plan          @default(ESSENTIAL)
  status       BookingStatus @default(PENDING)
  totalAmount  Int?
  currency     String        @default("USD")
  paymentRef   String?
  // Payment method: FULL (one-time) or BNPL (deposit + monthly instalments).
  paymentMethod String       @default("FULL")
  downPayment  Int?          // deposit paid today when paymentMethod = BNPL
  installments Int?          // number of monthly instalments for the remainder
  travelDate   DateTime?
  surgeryDate  DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Cascade: deleting a user removes their bookings (and, below, everything
  // hanging off a booking). report is SetNull so deleting a report never blocks.
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  report   Report?   @relation(fields: [reportId], references: [id], onDelete: SetNull)
  hospital Hospital  @relation(fields: [hospitalId], references: [id])

  recoveryPlan    RecoveryPlan?
  familyLinks     FamilyLink[]
  statusUpdates   BookingStatusUpdate[]
  milestones      BookingMilestone[]
  payment         Payment?

  @@map("bookings")
}

// Money ledger for a checkout. One Payment per Razorpay order. This is the
// idempotency anchor and source of truth for what was actually charged — the
// Booking (the business object) is only confirmed once a Payment is CAPTURED.
// See docs/razorpay/RAZORPAY_INTEGRATION.md for the ACID rules.
model Payment {
  id                 String        @id @default(cuid())
  bookingId          String?       @unique // linked once the booking is confirmed
  userId             String
  // Razorpay identifiers — both unique so a replayed verify/webhook is a no-op.
  razorpayOrderId    String        @unique // order_... (created first, server-side)
  razorpayPaymentId  String?       @unique // pay_...   (after the customer pays)
  razorpaySignature  String?
  // Money — amount is in the smallest currency unit (paise when currency=INR).
  amount             Int
  currency           String        @default("INR")
  method             String?       // card | emi | paylater | cardless_emi | upi | netbanking
  emiMonths          Int?          // tenure when method = emi
  status             PaymentStatus @default(CREATED)
  // Audit
  notes              Json?
  failureReason      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  events  PaymentEvent[]

  @@map("payments")
}

// One row per Razorpay webhook delivery. eventId is unique → replayed webhooks
// (Razorpay retries on non-2xx) are dropped idempotently.
model PaymentEvent {
  id        String   @id @default(cuid())
  paymentId String
  eventId   String   @unique // x-razorpay-event-id header
  type      String            // payment.captured, order.paid, refund.created, payment.dispute.created ...
  payload   Json
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_events")
}

enum PaymentStatus {
  CREATED    // order made, awaiting payment
  AUTHORIZED // funds held (payment_capture = manual)
  CAPTURED   // money settled — success
  FAILED
  REFUNDED
  DISPUTED   // chargeback opened
}

enum Plan {
  ESSENTIAL
  COMFORT
  PREMIUM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model RecoveryPlan {
  id             String   @id @default(cuid())
  userId         String
  bookingId      String   @unique
  checkIns       Json?
  tips           Json?
  handoff        Json?
  insuranceClaim Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Cascade from both the user and the booking it belongs to.
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("recovery_plans")
}

model FamilyLink {
  id         String   @id @default(cuid())
  patientId  String
  memberId   String?
  bookingId  String
  email      String?
  name       String?
  relation   String?
  accessCode String   @unique @default(cuid())
  createdAt  DateTime @default(now())

  // patient/booking cascade with the patient's account; member only unlinks
  // (deleting a family MEMBER account must not delete the patient's link record).
  patient User    @relation("PatientFamily", fields: [patientId], references: [id], onDelete: Cascade)
  member  User?   @relation("FamilyMember", fields: [memberId], references: [id], onDelete: SetNull)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("family_links")
}

// ─── New Dynamic Data Models ──────────────────────────────────────────────────

model StayOrGoTemplate {
  id               String @id @default(cuid())
  procedure        String
  homeCountry      String
  homeCost         String
  homeWaitTime     String
  homeSuccessRate  String
  homeRisk         String
  homeQuality      String
  indiaCost        String
  indiaWaitTime    String
  indiaSuccessRate String
  indiaRisk        String
  indiaQuality     String
  recommendation   String
  reasoning        String
  summary          Json
  riskTimeline     Json

  @@unique([procedure, homeCountry])
  @@map("stay_or_go_templates")
}

model TripPlanTemplate {
  id             String  @id @default(cuid())
  procedure      String
  destination    String
  timeline       Json
  costs          Json
  totalEstimate  String
  travelTips     Json
  insuranceAlert String?

  @@unique([procedure, destination])
  @@map("trip_plan_templates")
}

model FlightOption {
  id          String  @id @default(cuid())
  origin      String
  destination String
  airline     String
  price       Int
  duration    String
  stops       String?
  label       String?
  bookingUrl  String?

  @@map("flight_options")
}

model InsurancePlan {
  id          String  @id @default(cuid())
  name        String  @unique
  tagline     String?
  pricePerDay Int
  coverage    String
  features    Json
  recommended Boolean @default(false)
  bookingUrl  String?

  @@map("insurance_plans")
}

// One row per booking-service step in "Generate My Trip" (visa/flight/hotel/cab
// + the internal quotation). Persists the patient's progress through the vendor
// hand-off checklist: which steps are confirmed/skipped, the uploaded proof
// (granted e-Visa, flight ticket) and any validation result. Deep-links are
// recomputed on read, not stored, so vendor URL changes don't need a migration.
model TripServiceStep {
  id            String   @id @default(cuid())
  userId        String
  hospitalId    String
  type          String   // quotation | visa | flight | hotel | cab
  provider      String
  status        String   @default("not_started") // not_started | pending | confirmed | skipped
  // Relative path (under uploads/trip-proofs) of the uploaded proof document.
  proofPath     String?
  // Validation result / user-supplied metadata (visa number, expiry, notes).
  meta          Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One step of each type per patient+hospital trip.
  @@unique([userId, hospitalId, type])
  @@map("trip_service_steps")
}

model RecoveryProtocol {
  id        String @id @default(cuid())
  procedure String @unique
  checkIns  Json
  tips      Json
  handoff   Json

  @@map("recovery_protocols")
}

// The intake treatment catalog (the chat's "What treatment?" step). Was a
// hardcoded array in the frontend; now DB-backed so admins edit it in the Data
// Manager and the picker always reflects the DB. `specialty` maps a treatment to
// Hospital.specialty for downstream ranking; `aiAdded` flags rows created from a
// patient's free-typed "Other" answer (classified/normalized by the AI).
model Treatment {
  id        String   @id @default(cuid())
  slug      String   @unique // stable id sent to the API (e.g. "orthopedic")
  label     String // shown in the picker, may include an emoji
  specialty String? // e.g. "Orthopedic" — matches Hospital.specialty for ranking
  sortOrder Int      @default(0) // ascending display order in the picker
  active    Boolean  @default(true) // hidden from the picker when false
  aiAdded   Boolean  @default(false) // true when created from a user's free-typed "Other"
  createdAt DateTime @default(now())

  @@map("treatments")
}

// First-party lead captured from the intake chat BEFORE signup, so an abandoned
// chat is still a follow-up-able lead. Deliberately holds identity + funnel
// metadata ONLY — never the free-text symptom description (PHI stays with the
// authenticated Journey). Distinct from the scraping `Lead` model. `email` is the
// upsert key; on signup the matching row is marked CONVERTED and linked to userId.
model Inquiry {
  id          String    @id @default(cuid())
  name        String?
  email       String    @unique
  phone       String?
  country     String?
  treatment   String?
  city        String?
  urgency     String?
  travelDate  DateTime?
  insurance   String?
  source      String    @default("chat")
  status      String    @default("NEW") // NEW | CONVERTED
  userId      String? // set when the lead signs up
  convertedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("inquiries")
}

model BookingStatusUpdate {
  id        String   @id @default(cuid())
  bookingId String
  status    String
  message   String
  icon      String   @default("⚕️")
  postedBy  String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_status_updates")
}

model BookingMilestone {
  id        String  @id @default(cuid())
  bookingId String
  label     String
  done      Boolean @default(false)
  active    Boolean @default(false)
  sequence  Int

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_milestones")
}

// ─── Admin: Botasaurus scrape jobs ────────────────────────────────────────────

model ScrapeJob {
  id          String          @id @default(cuid())
  target      String          // 'jci' | 'surgeons' | 'prices'
  params      Json?           // { location?, hospitalName?, ... }
  status      ScrapeStatus    @default(PENDING)
  created     Int             @default(0)
  updated     Int             @default(0)
  skipped     Int             @default(0)
  stages      Json?           // per-stage breakdown for combined ('full') jobs
  summary     Json?           // run summary: combination + fetched/foreign/new/updated
  logPath     String?
  output      String?         // tail of stdout/stderr for the admin to inspect
  error       String?
  triggeredBy String?         // admin user id
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("scrape_jobs")
}

enum ScrapeStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// ─── Leads: medical-tourism prospecting (YouTube now; Reddit/Quora later) ──────

enum LeadSource {
  YOUTUBE
  REDDIT
  QUORA
}

enum LeadRegion {
  USA
  MIDDLE_EAST
  AFRICA
  OTHER
}

enum LeadStatus {
  NEW
  REVIEWED
  CONTACTED
  QUALIFIED
  REJECTED
}

model Lead {
  id           String     @id @default(cuid())
  source       LeadSource @default(YOUTUBE)
  externalId   String     // platform id (YouTube video id)
  title        String
  description  String?
  url          String
  thumbnailUrl String?
  channelId    String?
  channelTitle String?
  publishedAt  DateTime?
  isShort      Boolean    @default(false)
  region       LeadRegion @default(OTHER)
  regionCode   String?    // ISO country code used in search / detected from channel
  lang         String?
  viewCount    Int?
  likeCount    Int?
  commentCount Int?
  // Heuristic scoring
  intentScore     Int   @default(0) // 0-100
  matchedKeywords Json?
  query           String?           // the search query that surfaced it
  // Transcript + AI analysis (AI reads the full transcript to qualify/score)
  transcript   String?   @db.Text // fetched video transcript (captions)
  aiLead       Boolean?  // genuine medical-tourism lead?
  aiConfidence Int?      // 0-100 (transcript-based lead score)
  aiPersona    String?   // 'undecided' | 'cant_afford' | 'suffering' | 'researching'
  aiProcedure  String?   // extracted condition / procedure
  aiSummary    String?
  // AI category for the lead-analytics dashboard (classified from the transcript)
  category           LeadCategory? // null until classified
  categoryReason     String?
  categoryConfidence Int?          // 0-100 (ensemble agreement / model self-report)
  categoryVotes      Json?         // ensemble ballots, e.g. { "LEAD": 2, "PARTNER": 1 }
  needsReview        Boolean       @default(false) // low confidence / tag clash / split vote → human
  reviewedBy         String?       // admin who confirmed/overrode the category
  reviewedAt         DateTime?
  categorizedAt      DateTime?
  // Workflow
  status    LeadStatus @default(NEW)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([source, externalId])
  @@index([source, status])
  @@index([region])
  @@index([intentScore])
  @@index([category])
  @@index([needsReview])
  @@map("leads")
}

// Raw capture of EVERY video returned from a source during a generation run —
// kept for later analysis, regardless of whether it qualified as a Lead. The
// `leads` table stays the qualified-only set shown in the admin UI; this table is
// the full funnel (including videos dropped at the heuristic floor or by the AI
// gate). No extra quota cost: snippet data comes free with the search we already
// pay for; stats/AI fields are only filled for candidates we already enrich.
model CapturedVideo {
  id           String     @id @default(cuid())
  source       LeadSource @default(YOUTUBE)
  externalId   String     // platform id (YouTube video id)
  title        String
  description  String?
  url          String
  thumbnailUrl String?
  channelId    String?
  channelTitle String?
  publishedAt  DateTime?
  isShort      Boolean    @default(false)
  region       LeadRegion @default(OTHER)
  regionCode   String?
  lang         String?
  viewCount    Int?
  likeCount    Int?
  commentCount Int?
  // Heuristic scoring (computed for every captured video)
  intentScore     Int     @default(0) // 0-100
  matchedKeywords Json?
  query           String?            // the search query that surfaced it
  // AI classification (only for candidates above the heuristic floor)
  aiLead       Boolean?
  aiConfidence Int?
  aiPersona    String?
  aiProcedure  String?
  aiSummary    String?
  // Capture/funnel metadata for analysis
  scored     Boolean  @default(false) // passed the heuristic minScore floor (was enriched + AI-classified)
  qualified  Boolean  @default(false) // passed every gate and became/updated a Lead
  dropReason String?  // why not qualified: 'below_minscore' | 'ai_rejected' | 'duplicate' | null when qualified
  lastJobId  String?  // the LeadJob that last saw it
  timesSeen  Int      @default(1)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  @@unique([source, externalId])
  @@index([source, qualified])
  @@index([intentScore])
  @@index([lastJobId])
  @@map("captured_videos")
}

model LeadJob {
  id           String     @id @default(cuid())
  source       LeadSource @default(YOUTUBE)
  status       String     @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  trigger      String?    // 'manual' | 'scheduled'
  params       Json?      // { regions, queryGroup, maxSearches }
  quotaUsed    Int        @default(0)
  found        Int        @default(0)
  created      Int        @default(0)
  updated      Int        @default(0)
  aiClassified Int        @default(0)
  error        String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime   @default(now())

  @@map("lead_jobs")
}

// ─── Bright Data social capture (Reddit / Quora / Instagram / Facebook) ────────
// Raw demand-discovery data scraped via Bright Data's Web Scraper API, kept for
// lead analysis. We SAVE EVERYTHING (full raw record JSON) and NEVER hard-delete —
// removal is a soft delete (deletedAt) so the historical dataset stays intact for
// improving the scoring/AI system later.
enum CapturePlatform {
  REDDIT
  QUORA
  INSTAGRAM
  FACEBOOK
  X
}

// AI verdict on what a captured post actually is, for the lead-analytics dashboard.
// Mirrors the BrightData query-pack segregation:
//   LEAD      = 🟢 a real patient/family seeking treatment abroad for their own situation;
//   PARTNER   = 🔵 a business partner — facilitator/agency/coordinator offering or seeking
//               a referral / commission / "we send patients" relationship;
//   MARKETING = 🔴 promo/ads/self-promotion/spam selling services;
//   NEWS      = 🔴 articles / informational broadcast;
//   OTHER     = 🔴 off-topic / irrelevant.
enum LeadCategory {
  LEAD
  PARTNER
  MARKETING
  NEWS
  OTHER
}

model SourceCapture {
  id         String          @id @default(cuid())
  platform   CapturePlatform
  externalId String          // platform id (reddit post_id, quora url, etc.)
  url        String?
  title      String?
  body       String?         @db.Text // post/answer/caption text
  author     String?
  postedAt   DateTime?       // when the post itself was published (from the raw record)
  raw        Json            // FULL Bright Data record — nothing is dropped
  // 3-Signal Qualifier (from the Curify query-pack): procedure + cost + origin
  hasProcedure Boolean @default(false)
  hasCost      Boolean @default(false)
  hasOrigin    Boolean @default(false)
  signalCount  Int     @default(0) // 0..3
  temperature  String? // 'hot' (3) | 'warm' (2) | 'cold' (<2)
  procedures   Json?   // matched procedure terms
  origins      Json?   // matched origin-country terms
  intentScore  Int     @default(0) // 0-100
  isSpam       Boolean @default(false) // academic-cheating/service spam — saved but hidden by default
  // AI category for the lead-analytics dashboard (classifyCategories, batched)
  category           LeadCategory? // null until classified (human review overwrites this = the gold label)
  aiCategory         LeadCategory? // the model's OWN prediction, preserved through human review (for the scorecard)
  categoryReason     String?       // one-line AI rationale
  categoryConfidence Int?          // 0-100 (ensemble agreement / model self-report)
  categoryVotes      Json?         // ensemble ballots, e.g. { "LEAD": 2, "PARTNER": 1 }
  needsReview        Boolean       @default(false) // low confidence / tag clash / split vote → human
  reviewedBy         String?       // admin who confirmed/overrode the category
  reviewedAt         DateTime?
  categorizedAt      DateTime?
  // provenance
  datasetId  String?
  snapshotId String?
  jobId      String?
  keyword    String? // the discovery keyword / search that surfaced it
  // Comment thread (fetched on demand via the Reddit Comments dataset)
  comments         Json?     // array of comment records
  commentsStatus   String?   // null | 'fetching' | 'done' | 'failed'
  commentsFetchedAt DateTime?
  // soft delete — rows are never physically removed
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([platform, externalId])
  @@index([platform, deletedAt])
  @@index([temperature])
  @@index([signalCount])
  @@index([postedAt])
  @@index([isSpam])
  @@index([category])
  @@index([needsReview])
  @@map("source_captures")
}

// One row per Bright Data collection run (trigger → snapshot → download).
model BrightDataJob {
  id            String          @id @default(cuid())
  platform      CapturePlatform
  datasetId     String
  snapshotId    String?
  mode          String // 'discover_keyword' | 'discover_search_url' | 'url'
  inputs        Json
  status        String          @default("PENDING") // PENDING|RUNNING|READY|DONE|FAILED
  records       Int             @default(0) // records delivered (≈ credits spent)
  saved         Int             @default(0) // rows upserted into source_captures
  creditsApprox Int             @default(0)
  trigger       String?         // 'manual' | 'scheduled'
  error         String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("brightdata_jobs")
}

// Tracks per-provider daily API quota consumption (resets per Pacific day) so we
// can cap YouTube usage at a configured fraction (default 70%) of the free quota.
model ApiQuotaUsage {
  id        String   @id @default(cuid())
  provider  String   // 'youtube'
  day       String   // 'YYYY-MM-DD' in America/Los_Angeles
  unitsUsed Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([provider, day])
  @@map("api_quota_usage")
}

// ─── Sentinel: anti-scrape security watch ─────────────────────────────────────
// One row per client IP that has tripped a guard (rate limit) or been blocked.
// Powers the admin "Sentinel" screen and the in-memory IP blocklist.

model SecurityEvent {
  id            String   @id @default(cuid())
  ip            String   @unique
  lastPath      String?  // last route the IP hit
  lastMethod    String?
  lastUserAgent String?
  rateLimitHits Int      @default(0) // # of 429s (throttler blocks)
  blockedHits   Int      @default(0) // # of requests rejected while IP was blocked
  totalHits     Int      @default(0) // rateLimitHits + blockedHits
  blocked       Boolean  @default(false)
  blockReason   String?
  blockedBy     String?  // admin user id/email who blocked it
  blockedAt     DateTime?
  firstSeen     DateTime @default(now())
  lastSeen      DateTime @updatedAt

  @@index([blocked])
  @@map("security_events")
}

// ─── Admin: System settings ───────────────────────────────────────────────────
// Key/value overrides for app configuration + integration credentials, editable
// from the admin "Settings" screen. The canonical list of settings (labels,
// types, defaults, which are secret) lives in code (settings.registry.ts); this
// table only stores the values an admin has changed. Effective value resolves as:
// DB override (here) ?? environment variable ?? code default.

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique // matches a key in the settings registry
  value     String   @db.Text // string-encoded (number/boolean serialized as text)
  category  String   // 'integrations' | 'leadgen' | 'scheduling' | 'system'
  updatedBy String?  // admin user id/email who last changed it
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
